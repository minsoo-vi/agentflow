# =============================================================================
# 샘플 값 안내 — 아래 키 이름만 참고하고, 실제 값은 로컬 .env에만 두세요(커밋 금지).
# =============================================================================
# Gemini / Tavily (시뮬·에이전트·검색 — 코드 에디터에 저장한 스크립트 맥락은 GEMINI로 처리)
# GEMINI_API_KEY=sample_replace_with_your_key
# TAVILY_API_KEY=sample_replace_with_your_key

# --- 시뮬레이션 텍스트 길이 (선택). vite.config define → src/config/simulationLimits.ts
# Tavily 검색 쿼리 최대 길이. API 상한은 400자.
# AF_TAVILY_MAX_QUERY_CHARS=400
#
# 긴 맥락을 검색어로 요약할 때 Gemini에 넣는 입력 글자 수 상한
# AF_TAVILY_SUMMARIZE_INPUT_CHARS=14000
#
# report·라우터 등에 쓰는 상류 맥락 글자 수 상한
# AF_REPORT_CONTEXT_CHARS=12000

# --- 보고서 서버 저장 (npm run dev / npm run start 의 Express)
# 저장 디렉터리 (미설정 시 프로젝트 루트 data/reports)
# AF_REPORTS_DIR=
# API 보호용 공유 비밀(선택). 설정 시 요청 헤더 x-agentflow-report-key 와 일치해야 함
# AF_REPORT_API_SECRET=
# 브라우저가 같은 값을 보내려면 .env 에 VITE_AF_REPORT_API_SECRET= 동일 문자열
# VITE_AF_REPORT_API_SECRET=

# --- Langfuse (선택) 청킹·RAG·에이전트 시뮬 스팬 — https://langfuse.com
# 공개+시크릿 둘 다 있어야 trace 기록(로컬 개발용). 운영에서는 키를 서버에 두고 프록시하는 것이 안전합니다.
# VITE_LANGFUSE_PUBLIC_KEY=
# VITE_LANGFUSE_SECRET_KEY=
# VITE_LANGFUSE_BASE_URL=https://cloud.langfuse.com
